{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base"
    ],
    "dependencyDashboard": true,
    "enabledManagers": [
        "github-actions",
        "pep621",
        "pip_requirements",
        "pip-compile",
        "poetry",
        "pre-commit"
    ],
    "packageRules": [
        {
            "matchManagers": [
                "github-actions"
            ],
            "groupName": "GitHub Actions"
        },
        {
            "matchManagers": [
                "pep621"
            ],
            "groupName": "Python dependencies"
        }
    ]
}